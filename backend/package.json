{
  "name": "ai-crypto-advisor-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate --schema=../database/schema.prisma && tsc",
    "start": "node dist/server.js",
    "migrate:deploy": "prisma migrate deploy --schema=../database/schema.prisma",
    "prisma:generate": "prisma generate --schema=../database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../database/schema.prisma",
    "prisma:studio": "prisma studio --schema=../database/schema.prisma",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "prisma": {
    "schema": "../database/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
