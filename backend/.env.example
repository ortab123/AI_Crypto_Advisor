# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — must match docker-compose.yml (or your own DB)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ai_crypto_advisor

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Allowed frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Groq AI — free key at https://console.groq.com
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

# CoinGecko public API
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
