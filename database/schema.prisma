generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String
  password    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  preferences UserPreferences?
  feedback    Feedback[]

  @@map("users")
}

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteAssets  String[]
  customAsset     String?
  investorType    String
  experienceLevel String
  riskTolerance   String
  investmentGoal  String
  preferredContent String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_preferences")
}

model Feedback {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType String
  contentId   String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, contentType, contentId])
  @@map("feedback")
}

model NewsVote {
  id           String   @id @default(cuid())
  userId       String
  voteType     String
  cryptoAssets String[]
  articleUrl   String
  source       String
  author       String?
  articleColors String[]
  createdAt    DateTime @default(now())

  @@map("news_votes")
}

model CoinVote {
  id              String   @id @default(cuid())
  userId          String
  coinSymbol      String
  voteType        String
  priceTrend      String
  volatilityLevel String
  createdAt       DateTime @default(now())

  @@map("coin_votes")
}

model InsightVote {
  id           String   @id @default(cuid())
  userId       String
  insightId    String
  voteType     String
  cryptoAssets String[]
  riskLevel    String
  createdAt    DateTime @default(now())

  @@map("insight_votes")
}

model MemeVote {
  id           String   @id @default(cuid())
  userId       String
  memeId       String
  reactionType String
  cryptoAssets String[]
  memeStyle    String?
  createdAt    DateTime @default(now())

  @@map("meme_votes")
}

model RedditVote {
  id           String   @id @default(cuid())
  userId       String
  postId       String
  voteType     String
  cryptoAssets String[]
  postTopic    String?
  createdAt    DateTime @default(now())

  @@map("reddit_votes")
}
