# Backend API base URL (used in all fetch calls at runtime — baked in at Vite build time)
# Development: http://localhost:3001/api
# Production:  set to your deployed Render URL, e.g. https://ai-crypto-advisor-backend.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# Dev server proxy target — must match backend PORT (used in vite.config.ts, dev only)
VITE_BACKEND_URL=http://localhost:3001

# Dev server port
VITE_PORT=5173
